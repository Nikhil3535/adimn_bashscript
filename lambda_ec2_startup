import boto3

def lambda_handler(event, context):
    instance_id = "i-08c2a02f03d267bca"
    region = "eu-north-1"

    ec2 = boto3.client('ec2', region_name=region)

    action = event.get("action", "start").lower()
    
    if action == "start":
        ec2.start_instances(InstanceIds=[instance_id])
        print(f"Triggered start for instance: {instance_id}")
        return {"statusCode": 200, "body": f"Triggered start for {instance_id}"}
    
    elif action == "stop":
        ec2.stop_instances(InstanceIds=[instance_id])
        print(f"Triggered stop for instance: {instance_id}")
        return {"statusCode": 200, "body": f"Triggered stop for {instance_id}"}
    
    else:
        return {"statusCode": 400, "body": "Invalid action"}
